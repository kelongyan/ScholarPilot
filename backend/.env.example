# --- Application ---
APP_NAME=ScholarPilot
DEBUG=false

# --- Storage (Phase 1 dependencies) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/scholarpilot
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# --- LLM provider ---
# Provider can be openai | qwen | deepseek | local (Phase 1 implements concrete adapters)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Embedding provider ---
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
