# --- Application ---
APP_NAME=Kairos
DEBUG=false

# --- Storage ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/kairos
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=chunks
# Local directory for uploaded PDFs and parsed artifacts.
STORAGE_DIR=storage

# --- LLM provider ---
# Provider can be: openai | anthropic | local
#   openai    -> OpenAI and any OpenAI-compatible endpoint (Qwen, DeepSeek,
#               local vLLM/Ollama via LLM_BASE_URL override)
#   anthropic -> Anthropic Claude
#   local     -> local model via OpenAI-compatible endpoint (e.g. Ollama /v1)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Embedding provider ---
# Provider can be: openai | local
#   openai -> OpenAI-compatible embedding endpoint
#   local  -> sentence-transformers (install: uv sync --extra local)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- RAG ---
RETRIEVAL_TOP_K=5
SPARSE_RETRIEVAL_TOP_K=8
RERANK_TOP_K=5
RERANKER_PROVIDER=simple
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Async (RQ) ---
RQ_QUEUE_NAME=default

# --- Auth / RBAC ---
# Development default keeps auth disabled. Set AUTH_ENABLED=true to require
# Authorization: Bearer <token> on protected API routes.
AUTH_ENABLED=false
AUTH_JWT_SECRET=
AUTH_ADMIN_TOKEN=
AUTH_KB_MANAGER_TOKEN=
AUTH_USER_TOKEN=
AUTH_DEV_ACTOR_ID=system
